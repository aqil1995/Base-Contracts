pragma solidity ^0.8.20;

contract NameStorage {
    string public name;

    constructor(string memory _initialName) {
        name = _initialName;
    }

    function setName(string memory _newName) public {
        name = _newName;
    }

    function getName() public view returns (string memory) {
        return name;
    }
}
