pragma solidity ^0.8.20;

contract OwnerStorage {
    address public owner;

    constructor() {
        owner = msg.sender;
    }

    function setOwner(address _newOwner) public {
        owner = _newOwner;
    }

    function getOwner() public view returns (address) {
        return owner;
    }
}
