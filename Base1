pragma solidity ^0.8.20;

contract SimpleStorage {
    
    // State variable - stored on-chain permanently
    string public message;

    // Constructor runs only once when the contract is deployed
    constructor(string memory _initialMessage) {
        message = _initialMessage;
    }

    // Public function to update the stored message
    function setMessage(string memory _newMessage) public {
        message = _newMessage;
    }

    // Optional: view function to read the message (though not strictly needed
    // since `message` is already public)
    function getMessage() public view returns (string memory) {
        return message;
    }
}
