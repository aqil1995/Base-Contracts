pragma solidity ^0.8.20;

contract ScoreStorage {
    uint256 public score;

    constructor(uint256 _initialScore) {
        score = _initialScore;
    }

    function updateScore(uint256 _newScore) public {
        score = _newScore;
    }

    function getScore() public view returns (uint256) {
        return score;
    }
}
