pragma solidity ^0.8.20;

contract TimestampStorage {
    uint256 public timestamp;

    constructor() {
        timestamp = block.timestamp;
    }

    function updateTimestamp() public {
        timestamp = block.timestamp;
    }

    function getTimestamp() public view returns (uint256) {
        return timestamp;
    }
}
