pragma solidity ^0.8.20;

contract PriceStorage {
    uint256 public price;

    constructor(uint256 _initialPrice) {
        price = _initialPrice;
    }

    function setPrice(uint256 _newPrice) public {
        price = _newPrice;
    }

    function getPrice() public view returns (uint256) {
        return price;
    }
}
